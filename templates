<div class="container">
    <div class="box">
        <h2>✏️ Edit Cake</h2>

        {% if cake.image %}
        <div class="cake-preview">
            <img src="{{ cake.image }}" alt="{{ cake.name }}">
            <h3>{{ cake.name }}</h3>
        </div>
        {% endif %}

        <form method="POST">
            <div class="form-group">
                <label for="name">🍰 Cake Name</label>
                <input id="name" name="name" value="{{ cake.name }}" required placeholder="Enter cake name">
            </div>

            <div class="form-group">
                <label for="price">💰 Price (THB)</label>
                <input id="price" name="price" type="number" step="0.01" min="0" value="{{ cake.price }}" required placeholder="0.00">
