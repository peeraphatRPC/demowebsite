            <div class="form-group">
                <label for="image">🖼️ Image URL</label>
                <input id="image" name="image" value="{{ cake.image }}" placeholder="https://example.com/image.jpg">
            </div>

            <div class="form-group">
                <label for="stock">📦 Stock Quantity</label>
                <input id="stock" name="stock" type="number" min="0" value="{{ cake.stock or 0 }}" required placeholder="0">
            </div>

            <div class="form-group">
                <label for="category_id">🏷️ Category</label>
                <select id="category_id" name="category_id">
                    <option value="">Select Category</option>
                    {% for category in categories %}
                    <option value="{{ category.id }}" {% if category.id == cake.category_id %}selected{% endif %}>{{ category.name }}</option>
                    {% endfor %}
                </select>
            </div>

            <button type="submit">✅ Update Cake</button>
        </form>

